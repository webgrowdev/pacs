generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// Para cambiar de motor de base de datos:
//   1. Ajusta DATABASE_PROVIDER en .env (mysql o postgresql)
//   2. Ejecuta: npm run db:switch
//   3. Luego: npx prisma migrate dev  (o prisma db push)
//
// El script db:switch actualiza automáticamente el provider de este bloque.
// ─────────────────────────────────────────────────────────────────────────────
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  DOCTOR
  PATIENT
}

enum StudyStatus {
  UPLOADED
  IN_REVIEW
  REPORTED
  PUBLISHED
}

enum StudySource {
  MANUAL_UPLOAD
  DICOM_SCP
  DICOMWEB
}

enum ReportStatus {
  DRAFT
  FINAL
  SIGNED
  ADDENDUM
}

model Role {
  id    String   @id @default(cuid())
  name  RoleName @unique
  users User[]
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  passwordHash        String
  firstName           String
  lastName            String
  licenseNumber       String?                          // Matrícula profesional
  specialty           String?                          // Especialidad médica
  isActive            Boolean     @default(true)
  mustChangePassword  Boolean     @default(false)
  passwordChangedAt   DateTime?                        // C3: Updated on each password change to invalidate old tokens
  roleId              String
  role                Role        @relation(fields: [roleId], references: [id])
  doctorReports       Report[]    @relation("DoctorReports")
  uploadedStudies     Study[]     @relation("UploaderStudies")
  assignedStudies     Study[]     @relation("AssignedDoctor")
  patientAccess       PatientPortalAccess?
  auditLogs           AuditLog[]
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  peerReviews         PeerReview[] @relation("PeerReviewsGiven")
  criticalNotifications CriticalNotification[] @relation("CriticalNotificationsReceived")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Patient {
  id               String               @id @default(cuid())
  internalCode     String               @unique
  firstName        String
  lastName         String
  documentId       String               @unique        // DNI
  cuil             String?                             // CUIL (formato: XX-XXXXXXXX-X)
  dateOfBirth      DateTime
  sex              String
  email            String?
  phone            String?
  healthInsurance      String?                         // Nombre de la obra social / prepaga
  healthInsurancePlan  String?                         // Plan de la cobertura
  healthInsuranceMemberId String?                      // Número de afiliado
  studies          Study[]
  patientAccess    PatientPortalAccess?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Study {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  modality        String
  studyDate       DateTime
  status          StudyStatus     @default(UPLOADED)
  description     String?         @db.Text
  requestingDoctorName  String?                        // Médico solicitante externo
  requestingDoctorEmail String?                        // Email del médico solicitante (para distribución automática)
  insuranceOrderNumber  String?                        // Número de orden de la cobertura
  metadataJson    Json?
  radiationDoseJson Json?                              // CTDIvol (mGy), DLP (mGy·cm), effectiveDose (mSv)
  uploadedById    String
  uploadedBy      User            @relation("UploaderStudies", fields: [uploadedById], references: [id])
  assignedDoctorId String?
  assignedDoctor  User?           @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  source          StudySource     @default(MANUAL_UPLOAD)
  studyInstanceUid String?
  callingAeTitle  String?
  // B7: Worklist claim mechanism — tracks which doctor is actively reading the study
  claimedByDoctorId String?
  claimedAt         DateTime?
  series          StudySeries[]
  dicomFiles      DicomFile[]
  reports         Report[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([patientId])
}

model StudySeries {
  id                String      @id @default(cuid())
  studyId           String
  study             Study       @relation(fields: [studyId], references: [id])
  seriesInstanceUid String
  seriesNumber      Int?
  description       String?     @db.Text
  modality          String?
  dicomFiles        DicomFile[]
  createdAt         DateTime    @default(now())
}

model DicomFile {
  id              String      @id @default(cuid())
  studyId         String
  study           Study       @relation(fields: [studyId], references: [id])
  seriesId        String?
  series          StudySeries? @relation(fields: [seriesId], references: [id])
  filePath        String      @db.Text
  fileName        String
  mimeType        String
  fileSize        Int
  sopInstanceUid  String?
  instanceNumber  Int?
  metadataJson    Json?
  createdAt       DateTime    @default(now())
}

model Report {
  id                String               @id @default(cuid())
  studyId           String
  study             Study                @relation(fields: [studyId], references: [id])
  doctorId          String
  doctor            User                 @relation("DoctorReports", fields: [doctorId], references: [id])
  clinicalIndication String?             @db.Text   // Indicación clínica / motivo de consulta (obligatorio)
  findings          String               @db.Text
  conclusion        String               @db.Text
  patientSummary    String?              @db.Text
  status            ReportStatus         @default(DRAFT)
  draftedAt         DateTime?
  finalizedAt       DateTime?
  signedAt          DateTime?                        // Timestamp exacto de firma
  pdfPath           String?              @db.Text

  // ─── Hallazgo crítico/STAT ────────────────────────────────────────────────
  isCritical        Boolean              @default(false)
  criticalAt        DateTime?            // Cuando se marcó como crítico
  criticalReason    String?              @db.Text    // Descripción del hallazgo crítico

  // ─── Versioning & addendum ────────────────────────────────────────────────
  versionNumber     Int                  @default(1)
  parentReportId    String?
  parentReport      Report?              @relation("ReportVersions", fields: [parentReportId], references: [id])
  childReports      Report[]             @relation("ReportVersions")
  isAddendum        Boolean              @default(false)
  addendumReason    String?              @db.Text
  addendumAt        DateTime?
  addendumByUserId  String?

  // ─── Content integrity ────────────────────────────────────────────────────
  signatureHash     String?              // SHA-256 of findings|conclusion stored on model

  // ─── Structured scores (BI-RADS, TI-RADS, PI-RADS, LI-RADS, chest) ───────
  structuredScores  Json?                // { birads?: {...}, tirads?: {...}, pirads?: {...}, lirads?: {...}, chest?: {...} }

  // ─── AI attribution ───────────────────────────────────────────────────────
  aiUsed            Boolean              @default(false)
  aiModel           String?              // e.g. "gpt-4o-mini", "local-template"
  aiSessions        Json?                // [{requestedAt, model, section, action, editedByUser}]

  measurements      ReportMeasurement[]
  documents         GeneratedDocument[]
  keyImages         KeyImage[]
  peerReviews       PeerReview[]
  criticalNotifications CriticalNotification[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([studyId])
}

model ReportMeasurement {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id])

  // ─── Primary evidence references (DICOM identifiers) ─────────────────────
  sopInstanceUid      String?   // (0008,0018) — exact image
  seriesInstanceUid   String?   // (0020,000E)
  studyInstanceUid    String?   // (0020,000D)
  frameOfReferenceUid String?   // (0020,0052)
  instanceNumber      Int?      // DICOM instance number
  frameIndex          Int?      // 0-based frame within multi-frame instance

  // ─── Geometry ─────────────────────────────────────────────────────────────
  coordinatesJson     Json?     // [{x,y}, ...] in image pixel space
  imageWidth          Int?
  imageHeight         Int?

  // ─── Tool & result ────────────────────────────────────────────────────────
  toolName            String?   // exact CornerstoneJS toolName: "LengthTool", "EllipticalROITool"
  type                String    // "LINEAR", "ANGLE", "ROI", "PROBE"
  label               String
  value               Float
  unit                String
  extraStatsJson      Json?     // {mean, stdDev, min, max, area, ...}

  // ─── Attribution ──────────────────────────────────────────────────────────
  createdByUserId     String?   // userId of the doctor who created the measurement

  // ─── Lifecycle ────────────────────────────────────────────────────────────
  isActive            Boolean  @default(true)
  deletedAt           DateTime?
  deletedByUserId     String?
  version             Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatientPortalAccess {
  id            String   @id @default(cuid())
  patientId     String   @unique
  patient       Patient  @relation(fields: [patientId], references: [id])
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
}

model GeneratedDocument {
  id             String   @id @default(cuid())
  reportId       String
  report         Report   @relation(fields: [reportId], references: [id])
  type           String
  filePath       String   @db.Text
  generatedById  String
  generatedAt    DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Sistema de módulos ───────────────────────────────────────────────────────

model Module {
  id            String         @id @default(cuid())
  code          String         @unique  // ej: "PACS", "AGENDA", "FACTURACION"
  name          String
  description   String         @db.Text
  version       String         @default("1.0.0")
  isActive      Boolean        @default(true)   // activo globalmente en el sistema
  dependencies  Json?                           // array de codes requeridos
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantModules TenantModule[]
}

model Tenant {
  id        String         @id @default(cuid())
  name      String                            // ej: "Hospital XYZ"
  slug      String         @unique            // ej: "hospital-xyz"
  cuit      String?                           // CUIT argentino (para facturación)
  isActive  Boolean        @default(true)
  config    Json?                             // configuración general del tenant
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  modules   TenantModule[]
}

model TenantModule {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  moduleId      String
  module        Module    @relation(fields: [moduleId], references: [id])
  isActive      Boolean   @default(true)
  config        Json?     // config específica de este módulo para este tenant
  licensedUntil DateTime?
  enabledAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, moduleId])
}

// ─── Plantillas de informes por modalidad ─────────────────────────────────────

model ReportTemplate {
  id                 String   @id @default(cuid())
  name               String                          // Nombre descriptivo de la plantilla
  modality           String?                         // CT, MRI, RX, US, etc. (null = genérica)
  findingsTemplate   String   @db.Text               // Texto pre-cargado para hallazgos
  conclusionTemplate String   @db.Text               // Texto pre-cargado para conclusión
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Viewer state persistence ─────────────────────────────────────────────────
// Persists each doctor's reading session so it survives refresh / logout / reopen.

model ViewerState {
  id          String   @id @default(cuid())
  studyId     String
  userId      String

  // Viewport parameters
  windowWidth   Float?
  windowCenter  Float?
  zoom          Float?
  panX          Float?
  panY          Float?
  rotation      Float    @default(0)
  isInverted    Boolean  @default(false)
  frameIndex    Int      @default(0)
  activeTool    String?

  // Full annotation snapshot — serialised csTools.annotation.state
  annotationSnapshot Json?

  savedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studyId, userId])
}

// ─── Key images (Key Object Selection equivalent) ─────────────────────────────

model KeyImage {
  id              String   @id @default(cuid())
  reportId        String
  report          Report   @relation(fields: [reportId], references: [id])
  studyId         String
  sopInstanceUid  String   // image this key frame belongs to
  instanceNumber  Int?
  frameIndex      Int?
  description     String?
  createdByUserId String
  createdAt       DateTime @default(now())
}

// ─── C1: Refresh token revocation (server-side) ───────────────────────────────
// Stores a hashed record of every issued refresh token so logout can invalidate them.
// HIPAA §164.312(a)(2)(iii): automatic log-off / session termination.

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique  // SHA-256 of the raw JWT refresh token
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?           // Non-null = token has been invalidated
  createdAt DateTime  @default(now())

  @@index([tokenHash])
}

// ─── A4: Password reset token ─────────────────────────────────────────────────
// Single-use tokens for the forgot-password / reset-password flow.

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique  // SHA-256 of the raw reset token
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?           // Non-null = token has been consumed
  createdAt DateTime  @default(now())

  @@index([tokenHash])
}

// ─── Revisión por pares (Peer Review) ────────────────────────────────────────
// Un segundo radiólogo puede revisar un informe finalizado y marcar discrepancias.

model PeerReview {
  id               String   @id @default(cuid())
  reportId         String
  report           Report   @relation(fields: [reportId], references: [id])
  reviewerDoctorId String
  reviewer         User     @relation("PeerReviewsGiven", fields: [reviewerDoctorId], references: [id])
  status           String   // "REVIEWED" | "DISCREPANT"
  discrepancyLevel String?  // "MINOR" | "MAJOR" | "CRITICAL" — solo cuando status=DISCREPANT
  comment          String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([reportId])
}

// ─── Notificaciones de hallazgo crítico/STAT ─────────────────────────────────
// Registro de quién recibió la notificación crítica y cuándo fue reconocida.

model CriticalNotification {
  id               String    @id @default(cuid())
  reportId         String
  report           Report    @relation(fields: [reportId], references: [id])
  notifiedUserId   String
  notifiedUser     User      @relation("CriticalNotificationsReceived", fields: [notifiedUserId], references: [id])
  notifiedAt       DateTime  @default(now())
  acknowledged     Boolean   @default(false)
  acknowledgedAt   DateTime?

  @@index([reportId])
}

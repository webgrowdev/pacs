# ═══════════════════════════════════════════════════════════════════════════════
# PACSMed Backend — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════════
#
# HIPAA / ANMAT COMPLIANCE NOTES:
#   - NEVER commit the actual .env file to source control
#   - Rotate ALL secrets immediately if accidentally exposed
#   - Use a secrets manager in production (AWS Secrets Manager, HashiCorp Vault)
#
# Generate cryptographically secure secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
# ANMAT Disposición 2318/02: software version must be traceable
APP_VERSION=1.0.0

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_PROVIDER=mysql
DATABASE_URL=mysql://pacsuser:STRONG_DB_PASSWORD@localhost:3306/pacsmed
# PostgreSQL alternative:
# DATABASE_URL=postgresql://pacsuser:STRONG_DB_PASSWORD@localhost:5432/pacsmed

# ─── JWT Secrets (HIPAA §164.312(a)(2)(i)) ───────────────────────────────────
# REQUIRED: minimum 32 chars, cryptographically random, different from each other
# Access token: 15 min expiry, stored in-memory only (never in localStorage)
# Refresh token: 7 day expiry, stored as httpOnly Secure SameSite=Strict cookie
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_GENERATED_BY_CRYPTO_COMMAND
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING_GENERATED_BY_CRYPTO

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_ROOT=../storage

# ─── URLs — MUST be HTTPS in production (HIPAA §164.312(a)(2)(b)) ────────────
APP_BASE_URL=https://pacsmed.yourhospital.com/api
PORTAL_BASE_URL=https://pacsmed.yourhospital.com

# ─── CORS — NO wildcard in production ────────────────────────────────────────
CORS_ORIGIN=https://pacsmed.yourhospital.com

# ─── DICOM Networking ────────────────────────────────────────────────────────
DICOM_SCP_PORT=11112
DICOM_AE_TITLE=PACSMED_SERVER

# DICOMweb authentication — configure AT LEAST ONE of the following:
#
# Option A: Bearer token for imaging equipment HTTP requests
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Equipment config: Authorization: Bearer <this token>
DICOM_SYSTEM_TOKEN=REPLACE_WITH_RANDOM_TOKEN_FOR_IMAGING_EQUIPMENT

# Option B: IP allowlist for trusted imaging network (comma-separated)
# ⚠️  Do NOT use '*' — it disables all authentication for DICOMweb endpoints.
# List only explicit, trusted IP addresses.
DICOM_ALLOWED_IPS=192.168.1.100,192.168.1.101

# ─── SMTP — TLS required in production ───────────────────────────────────────
# Port 587 = STARTTLS  |  Port 465 = SSL/TLS (set SMTP_SECURE=true)
# Emails NEVER contain clinical data — only login links and notifications
SMTP_HOST=smtp.yourhospital.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=pacsmed@yourhospital.com
SMTP_PASS=SMTP_PASSWORD_HERE
EMAIL_FROM=PACSMed <pacsmed@yourhospital.com>

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# ⚠️  HIPAA BAA REQUIRED before using with real patient data.
#     Without a signed BAA: https://openai.com/enterprise-privacy
#     do NOT set this key — the system will use local rule-based fallbacks.
#
#     PHI scrubbing is applied before all API calls, but does NOT replace a BAA.
#
# OPENAI_API_KEY=sk-...
# B3: Externalize the OpenAI model name so it can be updated without code changes.
OPENAI_MODEL=gpt-4o-mini

# ─── Parallel reports (A6) ───────────────────────────────────────────────────
# Set to true only with explicit institutional policy approval.
# When false (default), a 409 error is returned if another doctor already has
# an active report for the same study.
ALLOW_PARALLEL_REPORTS=false

# ─── SFTP Drop Folder ────────────────────────────────────────────────────────
# OS permissions: chmod 700 /path && chown sftp_user:pacsapp /path
SFTP_DROP_FOLDER=../sftp-drop

# ─── Orthanc DICOM viewer backend (optional) ─────────────────────────────────
# ORTHANC_URL=http://localhost:8042

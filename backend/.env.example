NODE_ENV=development
PORT=4000

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────────────────────────────────────
# Motor activo: "mysql" o "postgresql"
DATABASE_PROVIDER=mysql

# URL de conexión — ajustar según el motor elegido:
#
# MySQL / MariaDB (Hostinger, local, etc.)
DATABASE_URL=mysql://root:password@localhost:3306/pacs_mvp
#
# PostgreSQL (si cambias a postgresql en el futuro)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pacs_mvp

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Cambiar obligatoriamente en producción (mínimo 32 caracteres cada uno)
# ─────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars

# ─────────────────────────────────────────────────────────────────────────────
# ALMACENAMIENTO Y URLS
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_ROOT=../storage
APP_BASE_URL=http://localhost:4000

# Orígenes permitidos para CORS (separados por coma), en dev se permite todo
# CORS_ORIGIN=http://localhost:5173,https://mi-dominio.com

# =============================================================================
# PACSMed Frontend — Variables de entorno de PRODUCCIÓN
# =============================================================================
# Copia este archivo como .env.production antes de hacer el build:
#   cp .env.production.example .env.production
#   nano .env.production    (editar con tus URLs reales)
#   cd .. && ./scripts/deploy-hostinger.sh

# URL base del backend (sin barra final)
# En producción: la URL pública de tu VPS o servicio (Railway, Render, etc.)
VITE_API_URL=https://api.tu-dominio.com/api

# URL base para servir archivos DICOM y PDFs
VITE_FILES_URL=https://api.tu-dominio.com/files
